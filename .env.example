# =============================================================================
# ДЕПЛОЙ
# =============================================================================

# Домен для Caddy (HTTPS). Для локального теста оставить localhost —
# Caddy выдаст self-signed сертификат. Для продакшна — реальный домен,
# тогда Let's Encrypt сертификат выпускается автоматически.
DOMAIN=localhost

# HuggingFace токен — нужен при сборке образа (скачивание моделей pyannote)
# и в рантайме воркера. Лицензии нужно принять заранее:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_your_token_here

# =============================================================================
# GITHUB CONTAINER REGISTRY (GHCR)
# =============================================================================

# Полное имя образа в GHCR (без тега).
# Пример: ghcr.io/your-github-username/speech-analytics-gpu-server
GHCR_IMAGE=ghcr.io/your-github-username/speech-analytics-gpu-server

# Тег образа. Используется при сборке (build.sh) и на сервере (deploy.sh).
IMAGE_TAG=latest

# GitHub-логин и Personal Access Token для авторизации в GHCR.
# Локально (build.sh): нужен scope write:packages
# На сервере (deploy.sh): нужен scope read:packages (если пакет приватный)
# Создать токен: https://github.com/settings/tokens
GHCR_USER=your-github-username
GHCR_TOKEN=ghp_your_token_here

# =============================================================================
# БАЗА ДАННЫХ
# =============================================================================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=transcript
DB_USER=app
DB_PASSWORD=change_me_please

# =============================================================================
# REDIS / ОЧЕРЕДЬ
# =============================================================================

REDIS_URL=redis://redis:6379/0

# =============================================================================
# ML-МОДЕЛИ
# =============================================================================

WHISPER_MODEL=large-v3-turbo
WHISPER_LANGUAGE=ru
WHISPER_COMPUTE_TYPE=int8
WHISPER_BATCH_SIZE=32
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
MIN_SPEAKERS=2
MAX_SPEAKERS=4

# =============================================================================
# ЛИМИТЫ
# =============================================================================

MAX_FILE_SIZE_MB=300
MAX_DURATION_MIN=180
TASK_TIMEOUT_SECONDS=2700
TTL_HOURS=24
TMP_DIR=/tmp/transcripts
UPLOADS_DIR=/tmp/uploads

# =============================================================================
# WEBHOOK
# =============================================================================

WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=3
# Задержки перед попытками 1, 2, 3 (в секундах)
WEBHOOK_BACKOFF_SECONDS=5,30,120
# Разрешить http:// для webhook — только для локального тестирования
WEBHOOK_ALLOW_HTTP=false

# =============================================================================
# ЛОГИРОВАНИЕ
# =============================================================================

LOG_LEVEL=INFO
