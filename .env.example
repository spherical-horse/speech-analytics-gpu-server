# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=transcript
DB_USER=app
DB_PASSWORD=change_me_please

# Redis
REDIS_URL=redis://redis:6379/0

# HuggingFace — REQUIRED for pyannote models (accept licenses first)
HF_TOKEN=hf_your_token_here

# Models
WHISPER_MODEL=large-v3-turbo
WHISPER_LANGUAGE=ru
WHISPER_COMPUTE_TYPE=int8
WHISPER_BATCH_SIZE=32
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
MIN_SPEAKERS=2
MAX_SPEAKERS=4

# Limits
MAX_FILE_SIZE_MB=300
MAX_DURATION_MIN=180
TASK_TIMEOUT_SECONDS=2700
TTL_HOURS=24
TMP_DIR=/tmp/transcripts
UPLOADS_DIR=/tmp/uploads

# Webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_BACKOFF_SECONDS=5,30,120
# Set to true only for local testing with http:// URLs
WEBHOOK_ALLOW_HTTP=false

# Logging
LOG_LEVEL=INFO
